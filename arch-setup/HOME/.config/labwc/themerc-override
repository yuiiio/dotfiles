# window border
window.active.border.color: #9e9e9e
window.inactive.border.color: #444444

border.width: 1

# window titlebar background
window.active.title.bg.color: #d0d0d0
window.inactive.title.bg.color: #eeeeee

# window titlebar text
window.active.label.text.color: #1c1c1c
window.inactive.label.text.color: #bcbcbc
window.label.text.justify: center

# window buttons
window.active.button.unpressed.image.color: #1c1c1c
window.inactive.button.unpressed.image.color: #bcbcbc

snapping.overlay.region.bg.enabled: no
snapping.overlay.edge.bg.enabled: no
snapping.overlay.region.border.enabled: yes
snapping.overlay.edge.border.enabled: yes

osd.window-switcher.preview.border.width: 2
osd.window-switcher.preview.border.color: #dddda6,#000000,#dddda6
