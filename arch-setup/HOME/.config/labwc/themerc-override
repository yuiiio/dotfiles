# window border
window.active.border.color: #e0def4
window.inactive.border.color: #e0def4

# window titlebar background
window.active.title.bg.color: #eed0ff
window.inactive.title.bg.color: #e0def4

# window titlebar text
window.active.label.text.color: #191724
window.inactive.label.text.color: #191724
window.label.text.justify: center

# window buttons
window.active.button.unpressed.image.color: #191724
window.inactive.button.unpressed.image.color: #47435d

snapping.overlay.region.bg.enabled: yes
snapping.overlay.edge.bg.enabled: yes
snapping.overlay.region.border.enabled: yes
snapping.overlay.edge.border.enabled: yes

osd.bg.color: #e0def4

overview.bg.color: #323232aa
